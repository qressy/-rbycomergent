# Chattersift production environment.
# Copy this file to .env.production with `make deploy-init`, then edit the values marked USER EDIT.

# USER EDIT: public domain and Let's Encrypt contact.
CHATTERSIFT_SITE_DOMAIN=example.com
CADDY_SITE_ADDRESS=example.com, www.example.com
CADDY_ACME_EMAIL=admin@example.com

# Generated by scripts/bootstrap-deploy-env.
DJANGO_SECRET_KEY=
DJANGO_ADMIN_URL=
POSTGRES_PASSWORD=

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_ACCOUNT_ALLOW_REGISTRATION=True
DJANGO_ACCOUNT_EMAIL_VERIFICATION=mandatory
DJANGO_DEFAULT_FROM_EMAIL=Chattersift <noreply@example.com>
DJANGO_SERVER_EMAIL=Chattersift <noreply@example.com>
DJANGO_ADMIN_EMAIL=admin@example.com
DJANGO_EMAIL_SUBJECT_PREFIX=[Chattersift]
WEB_CONCURRENCY=1
CELERY_WORKER_CONCURRENCY=1
COMPRESS_ENABLED=False

# Internal Docker services.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=chattersift
POSTGRES_USER=chattersift
REDIS_URL=redis://redis:6379/0

# Email. Supported providers: smtp, amazon_ses, mailgun, postmark, brevo, resend, mailjet, mailersend.
CHATTERSIFT_EMAIL_PROVIDER=smtp
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Provider-specific Anymail values. Set only the values for your provider.
ANYMAIL_AMAZON_SES_CLIENT_PARAMS={}
ANYMAIL_MAILGUN_API_KEY=
ANYMAIL_MAILGUN_SENDER_DOMAIN=
ANYMAIL_POSTMARK_SERVER_TOKEN=
ANYMAIL_BREVO_API_KEY=
ANYMAIL_RESEND_API_KEY=
ANYMAIL_MAILJET_API_KEY=
ANYMAIL_MAILJET_SECRET_KEY=
ANYMAIL_MAILERSEND_API_TOKEN=

# Optional semantic matching.
CHATTERSIFT_SEMANTIC_LLM_MODEL=
CHATTERSIFT_SEMANTIC_LLM_API_KEY=
CHATTERSIFT_SEMANTIC_LLM_BASE_URL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional Sentry.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
