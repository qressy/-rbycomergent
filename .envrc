export DJANGO_READ_DOT_ENV_FILE="True"

# Activate the main worktree venv so branch worktrees share one environment.
_main_worktree="$(git worktree list --porcelain | awk 'NR==1{print $2}')"
_main_venv="$_main_worktree/.venv"
export VIRTUAL_ENV="$_main_venv"
PATH_add "$_main_venv/bin"

# Load shared config from the main worktree, then allow local overrides.
dotenv_if_exists "$_main_worktree/.env"
dotenv_if_exists ".env"
source_env_if_exists "$_main_worktree/.envrc.local"
source_env_if_exists ".envrc.local"
