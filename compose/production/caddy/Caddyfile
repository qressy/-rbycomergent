{
	# Runtime logs stay on stderr so Docker exposes them via `docker compose logs`.
	log {
		output stderr
		format json
		level INFO
	}

	servers {
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
		trusted_proxies_strict
	}

	email contact@chattersift.com
}

(access_log) {
	# Access logs are separate from Caddy's runtime logs and use a mounted volume.
	log {
		output file /var/log/caddy/access.log {
			mode 0644
			roll_size 100mb
			roll_keep 10
		}
		format json
		level INFO
	}
}

chattersift.com, www.chattersift.com {
	import access_log

	reverse_proxy django:5000 {
		header_up X-CSRFToken {header.X-CSRFToken}
	}
}

# Catch-all for custom domains behind Cloudflare Custom Hostnames.
# Cloudflare handles edge SSL; Caddy uses internal certs for the origin.
:443 {
	tls internal

	import access_log

	reverse_proxy django:5000 {
		header_up X-CSRFToken {header.X-CSRFToken}
	}
}
